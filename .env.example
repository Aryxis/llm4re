# Example .env for LLM4Re. Copy this to `.env` and fill in your own API keys and settings.

# If you want to use Etherscan for fetching contract ABIs, you need to provide your Etherscan API key here.
ETHERSCAN_API_KEY=...

# OpenAI API settings
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4-mini
